{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/atoms/*": [
        "./components/ui/atoms/*"
      ],
      "@/molecules/*": [
        "./components/ui/molecules/*"
      ],
      "@/organisms/*": [
        "./components/ui/organisms/*"
      ],
      "@/form/*": [
        "./components/ui/form/*"
      ],
      "@/layout/*": [
        "./components/ui/layout/*"
      ],
      "@/view/*": [
        "./components/view/*"
      ],
      "@/*": [
        "./*"
      ],
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "scripts/check-ddd.JS"
  ],
  "exclude": [
    "node_modules"
  ]
}